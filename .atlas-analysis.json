  "keyFeatures": [
    "Multi-tenant portal system with custom branding per client",
    "Event browsing and ticketing with real-time availability",
    "Secure payment processing via Stripe and Mercantil",
    "Firebase authentication with email verification",
    "Redux state management with encrypted persistence",
    "Responsive UI with Tailwind CSS and Radix UI components",
    "Mobile payment support including BCV integration",
    "Protected routes with authentication guards"
  ],
  "publicApiSurface": [
    "list_events_clients - Fetch events for a specific client",
    "tickets_list_event_sales_virtual - Get available tickets for an event",
    "tickets_lock_virtual - Lock tickets during purchase",
    "tickets_unlock_param_virtual - Unlock tickets if purchase fails",
    "order_created - Create a new order",
    "stripe_create_payment_intent - Initialize Stripe payment",
    "stripe_confirm_payment - Confirm Stripe payment",
    "api_mercantil_tdc_pay - Process credit card payment",
    "api_mercantil_tdd_pay - Process debit card payment",
    "api_mercantil_c2p_pay - Process C2P payment",
    "mobile_payment_bcv - Process mobile BCV payment",
    "send_email - Send notification emails"
  ]
